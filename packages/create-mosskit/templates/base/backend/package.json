{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "tsc --noEmit && bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:start": "docker compose down && docker compose up -d",
    "db:stop": "docker compose down"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "hono": "^4.10.7",
    "postgres": "^3.4.7",
    "shared": "workspace:*",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.8",
    "vitest": "^4.0.18"
  }
}
