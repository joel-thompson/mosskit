{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2023"
    ],
    "noEmit": true,
    "types": [
      "bun",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
